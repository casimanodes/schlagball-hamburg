# Strapi CMS
# Full URL of the Strapi instance (used for API calls and image URLs)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# API token created in Strapi Admin > Settings > API Tokens
STRAPI_API_TOKEN=

# Site URL (optional, used for metadata / canonical URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
