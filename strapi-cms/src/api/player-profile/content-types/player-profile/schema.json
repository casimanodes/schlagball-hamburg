{
  "kind": "collectionType",
  "collectionName": "player_profiles",
  "info": {
    "singularName": "player-profile",
    "pluralName": "player-profiles",
    "displayName": "PlayerProfile",
    "description": "Spielerprofile für die Vereinswebseite"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "age": {
      "type": "integer",
      "required": true
    },
    "rank": {
      "type": "string",
      "required": true
    },
    "position": {
      "type": "string",
      "required": true
    },
    "profileImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "bio": {
      "type": "text",
      "required": false
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    }
  }
}
